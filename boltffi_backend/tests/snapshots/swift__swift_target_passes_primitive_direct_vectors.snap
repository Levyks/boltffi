===== DemoFFI.swift =====
import Foundation
import DemoFFI

public struct FfiError: Error {
    public let message: String

    public init(message: String) {
        self.message = message
    }
}

public func sum(values: [Int32]) -> Int32 {
    return values.withUnsafeBufferPointer { __boltffi_values_buffer in
        return boltffi_function_demo_sum(__boltffi_values_buffer.baseAddress, UInt(__boltffi_values_buffer.count))
    }
}
