===== DemoFFI.swift =====
import Foundation
import DemoFFI

public struct FfiError: Error {
    public let message: String

    public init(message: String) {
        self.message = message
    }
}

public struct Person: Hashable, Equatable, Sendable {
    public var name: String

    public init(name: String) {
        self.name = name
    }

    @inlinable static func decode(from reader: inout WireReader) -> Person {
        Person(name: reader.readString())
    }

    @inlinable func encode(to writer: inout WireWriter) {
        writer.writeString(self.name)
    }
}

public struct Point: Hashable, Equatable, Sendable {
    public var x: Int32
    public var y: Int32

    public init(x: Int32, y: Int32) {
        self.x = x
        self.y = y
    }

    @usableFromInline init(fromC c: ___Point) {
        self.init(x: c.x, y: c.y)
    }

    @usableFromInline var cValue: ___Point {
        ___Point(x: x, y: y)
    }
}

public func refresh() async throws {
    let __boltffi_future = boltffi_function_demo_refresh()
    return try await boltffiAsyncCall(
        futureHandle: __boltffi_future,
        poll: boltffi_async_function_demo_refresh_poll,
        cancel: boltffi_async_function_demo_refresh_cancel,
        free: boltffi_async_function_demo_refresh_free
    ) { __boltffi_future, __boltffi_status in
        boltffi_async_function_demo_refresh_complete(__boltffi_future, __boltffi_status)
    }
}

public func loadName() async throws -> String {
    let __boltffi_future = boltffi_function_demo_load_name()
    return try await boltffiAsyncCall(
        futureHandle: __boltffi_future,
        poll: boltffi_async_function_demo_load_name_poll,
        cancel: boltffi_async_function_demo_load_name_cancel,
        free: boltffi_async_function_demo_load_name_free
    ) { __boltffi_future, __boltffi_status in
        let __boltffi_result = boltffi_async_function_demo_load_name_complete(__boltffi_future, __boltffi_status)
        defer { boltffi_free_buf(__boltffi_result) }
        return boltffiDecodeOwnedBuf(__boltffi_result.ptr, Int(__boltffi_result.len)) { __boltffi_reader in __boltffi_reader.readString() }
    }
}

public func loadPoint() async throws -> Point {
    let __boltffi_future = boltffi_function_demo_load_point()
    return try await boltffiAsyncCall(
        futureHandle: __boltffi_future,
        poll: boltffi_async_function_demo_load_point_poll,
        cancel: boltffi_async_function_demo_load_point_cancel,
        free: boltffi_async_function_demo_load_point_free
    ) { __boltffi_future, __boltffi_status in
        return Point(fromC: boltffi_async_function_demo_load_point_complete(__boltffi_future, __boltffi_status))
    }
}
