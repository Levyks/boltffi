===== DemoFFI.swift =====
import Foundation
import DemoFFI

public struct FfiError: Error {
    public let message: String

    public init(message: String) {
        self.message = message
    }
}

public final class Engine {
    @usableFromInline let handle: UInt64

    @usableFromInline init(handle: UInt64) {
        self.handle = handle
    }

    deinit {
        boltffi_release_class_demo_engine(handle)
    }

    public init() {
        self.handle = boltffi_init_class_demo_engine_new()
    }

    public func compute(value: UInt32) async throws -> UInt32 {
        let __boltffi_future = boltffi_method_class_demo_engine_compute(self.handle, value)
        return try await boltffiAsyncCall(
            futureHandle: __boltffi_future,
            poll: boltffi_async_method_class_demo_engine_compute_poll,
            cancel: boltffi_async_method_class_demo_engine_compute_cancel,
            free: boltffi_async_method_class_demo_engine_compute_free
        ) { __boltffi_future, __boltffi_status in
            return boltffi_async_method_class_demo_engine_compute_complete(__boltffi_future, __boltffi_status)
        }
    }
}
