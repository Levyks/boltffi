JNIEXPORT jbyteArray JNICALL Java_com_boltffi_demo_Native_boltffi_1function_1demo_1keep_1person(JNIEnv *env, jclass cls, jbyteArray person) {
    (void)cls;

    jbyte *__boltffi_person_ptr = NULL;
    jsize __boltffi_person_len = 0;

    if (person == NULL) {
        boltffi_jni_throw_illegal_argument(env, "BoltFFI array argument was null");
        goto __boltffi_error;
    }
    __boltffi_person_len = (*env)->GetArrayLength(env, person);
    __boltffi_person_ptr = (*env)->GetByteArrayElements(env, person, NULL);
    if (__boltffi_person_ptr == NULL) {
        goto __boltffi_error;
    }

    (void)env;
    FfiBuf_u8 __boltffi_result = boltffi_function_demo_keep_person((const uint8_t *)__boltffi_person_ptr, (uintptr_t)__boltffi_person_len);

    if (__boltffi_person_ptr != NULL) {
        (*env)->ReleaseByteArrayElements(env, person, __boltffi_person_ptr, JNI_ABORT);
        __boltffi_person_ptr = NULL;
    }

    return boltffi_jni_buffer_to_byte_array(env, __boltffi_result);
__boltffi_error:
    if (__boltffi_person_ptr != NULL) {
        (*env)->ReleaseByteArrayElements(env, person, __boltffi_person_ptr, JNI_ABORT);
        __boltffi_person_ptr = NULL;
    }
    return NULL;
}

