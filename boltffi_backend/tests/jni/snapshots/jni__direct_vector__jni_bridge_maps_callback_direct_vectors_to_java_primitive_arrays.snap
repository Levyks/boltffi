        goto fail;
    }
    if (!boltffi_jni_lookup_static_method_with_diagnostic(env, g____CollectorVTable_class, "com/boltffi/demo/CollectorCallbacks", "on_values", "on_values", "(J[I)V", "(J[I)V", &g____CollectorVTable_on_values_method)) {
        goto fail;
    }
    boltffi_register_callback_demo_collector(&g____CollectorVTable_vtable);
