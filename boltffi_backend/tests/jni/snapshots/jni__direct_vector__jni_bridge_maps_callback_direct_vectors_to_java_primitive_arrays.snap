}

static void boltffi_jni_unload____CollectorVTable_callbacks(JNIEnv *env) {
    if (g____CollectorVTable_class != NULL) {
        (*env)->DeleteGlobalRef(env, g____CollectorVTable_class);
    }
    g____CollectorVTable_class = NULL;
    g____CollectorVTable_free_method = NULL;
