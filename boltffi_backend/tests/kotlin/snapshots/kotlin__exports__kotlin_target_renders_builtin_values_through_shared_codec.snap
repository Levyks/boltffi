fun echoDuration(value: java.time.Duration): java.time.Duration {
    val __boltffi_value_wire = WireWriterPool.acquire(12)
    val __boltffi_value_writer = __boltffi_value_wire.writer
    __boltffi_value_writer.writeDuration(value)
    try {
        val __boltffi_result = Native.boltffi_function_demo_echo_duration(__boltffi_value_wire.bytes()) ?: throw IllegalStateException("null buffer returned")
        val __boltffi_reader = WireReader(__boltffi_result)
        return __boltffi_reader.readDuration()
    } finally {
        __boltffi_value_wire.close()
    }
}

