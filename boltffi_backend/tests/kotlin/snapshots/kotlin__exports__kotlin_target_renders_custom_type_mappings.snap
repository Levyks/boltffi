package com.boltffi.demo
@Suppress("FunctionName")
private object Native {
    @JvmStatic external fun boltffi_function_demo_keep_email(value: ByteArray): ByteArray?
}

fun keepEmail(value: java.net.URI): java.net.URI {
    val __boltffi_value_wire = WireWriterPool.acquire(4 + Utf8Codec.maxBytes(value.toString()))
    val __boltffi_value_writer = __boltffi_value_wire.writer
    __boltffi_value_writer.writeString(value.toString())
    try {
        val __boltffi_result = Native.boltffi_function_demo_keep_email(__boltffi_value_wire.bytes()) ?: throw IllegalStateException("null buffer returned")
        val __boltffi_reader = WireReader(__boltffi_result)
        return java.net.URI.create(__boltffi_reader.readString())
    } finally {
        __boltffi_value_wire.close()
    }
}
