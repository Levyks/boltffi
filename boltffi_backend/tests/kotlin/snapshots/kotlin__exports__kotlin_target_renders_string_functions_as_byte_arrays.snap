@file:OptIn(kotlin.ExperimentalUnsignedTypes::class)

package com.boltffi.demo
@Suppress("FunctionName")
private object Native {
    @JvmStatic external fun boltffi_function_demo_echo_string(message: ByteArray): ByteArray?
    @JvmStatic external fun boltffi_function_demo_echo_str(message: ByteArray): ByteArray?
}

fun echoString(message: String): String {
    val __boltffi_message_wire = WireWriterPool.acquire(4 + Utf8Codec.maxBytes(message))
    val __boltffi_message_writer = __boltffi_message_wire.writer
    __boltffi_message_writer.writeString(message)
    try {
        val __boltffi_result = Native.boltffi_function_demo_echo_string(__boltffi_message_wire.bytes()) ?: throw IllegalStateException("null buffer returned")
        val __boltffi_reader = WireReader(__boltffi_result)
        return __boltffi_reader.readString()
    } finally {
        __boltffi_message_wire.close()
    }
}

fun echoStr(message: String): String {
    val __boltffi_message_wire = WireWriterPool.acquire(4 + Utf8Codec.maxBytes(message))
    val __boltffi_message_writer = __boltffi_message_wire.writer
